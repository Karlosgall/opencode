{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    },
    "MongoDB": {
      "type": "local",
      "command": ["npx", "-y", "mongodb-mcp-server@latest", "--readOnly"],
      "enabled": true,
      "environment": {
        "MDB_MCP_CONNECTION_STRING": "mongodb://localhost:27017/"
      }
    },
    "mysql": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "github:benborla/mcp-server-mysql"],
      "enabled": true,
      "environment": {
        "MYSQL_HOST": "127.0.0.1",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASS": "",
        "MYSQL_DB": "tvs1"
      }
    }
  }
}
